{
  "name": "spinrank-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --persist-to=.wrangler/state",
    "deploy": "wrangler deploy",
    "db:local:migrate": "wrangler d1 migrations apply spinrank-db --local --persist-to=.wrangler/state",
    "db:local:seed": "wrangler d1 execute spinrank-db --local --persist-to=.wrangler/state --file=seed/dev_seed.sql",
    "db:remote:migrate": "wrangler d1 migrations apply spinrank-db --remote"
  },
  "dependencies": {
    "jose": "^6.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.10.0"
  }
}
